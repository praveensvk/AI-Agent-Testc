# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agent_test
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agent_test
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_agent_test
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Artifacts
ARTIFACTS_DIR=./artifacts
GENERATED_TESTS_DIR=./generated-tests
