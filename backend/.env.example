# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_agent_test
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/ai_agent_test

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# LLM Provider: "groq" or "ollama"
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2

# Ollama (fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Artifacts
ARTIFACTS_DIR=./artifacts
GENERATED_TESTS_DIR=./generated-tests
